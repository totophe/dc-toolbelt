{
  "name": "Node 24 Toolbox Light",
  "image": "ghcr.io/totophe/dc-toolbelt:node24-toolbox-light",
  "remoteUser": "node",
  "mounts": [
    "source=dc-toolbelt-config,target=/home/node/.dc-toolbelt,type=volume"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "editor.inlineSuggest.enabled": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      },
      "extensions": [
        "GoogleCloudTools.cloudcode",
        "anthropics.claude-code",
        "rust-lang.rust-analyzer",
        "ms-python.python",
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "remoteEnv": {
    "OP_SERVICE_ACCOUNT_TOKEN": "${localEnv:OP_SERVICE_ACCOUNT_TOKEN}"
  },
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": { "label": "Astro Dev", "onAutoForward": "notify" }
  },
  "postStartCommand": "sudo chown -R node:node /home/node/.dc-toolbelt || true && node --version && python --version && rustc --version && gcloud --version && scw version && op --version && ansible --version && astro --version && claude --version"
}
